# moves focus between windows in the current focused display
alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east

# delete focused space
alt - q : yabai -m space --destroy

# toggle window split type
alt - e : yabai -m window --toggle split

# toogle window layout
fn - b : yabai -m space --layout bsp
fn - t : yabai -m space --layout stack
fn - f : yabai -m space --layout float

# close window
alt - x : yabai -m window --close

# minimize window
alt - m : yabai -m window --minimize

alt - return : open -n -a "kitty"