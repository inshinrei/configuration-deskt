yabai -m config layout bsp
# yabai -m config menubar_opacity 0.0

yabai -m config                                  \
    top_padding                       50         \
    bottom_padding                    54         \
    left_padding                      8          \
    right_padding                     8          \
    window_gap                        10         \
    window_opacity                    on         \
    active_window_opacity             1.0        \
    normal_window_opacity             0.8        \
    window_shadow                     on         \
    window_animation_duration         0.0        \

yabai -m rule --add \
    app="^System Preferences$" sticky=on layer=above manage=off

borders active_color=0xfffc1414 inactive_color=0xff494d64 width=8.0 &

yabai -m signal --add event=display_changed action="borders active_color=0xfffc1414 inactive_color=0xff494d64 width=8.0" &

echo "yabai config loaded"